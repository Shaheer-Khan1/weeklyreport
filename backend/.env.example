# ─── Google OAuth Credentials ────────────────────────────────────────────────
# Paste the entire contents of your credentials.json here as a single line.
# Used in production (Render) so you don't have to upload the file.
# Example: GOOGLE_CREDENTIALS_JSON={"web":{"client_id":"...","client_secret":"...",...}}
GOOGLE_CREDENTIALS_JSON=

# ─── Gemini AI ────────────────────────────────────────────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ─── OAuth Redirect ───────────────────────────────────────────────────────────
# Must match exactly what you set in Google Cloud Console
REDIRECT_URI=http://localhost:8000/auth/callback

# ─── Frontend URL (for post-login redirect) ───────────────────────────────────
FRONTEND_URL=http://localhost:5500

# ─── Whisper model size (runs locally, no API key needed) ────────────────────
# Options: tiny, base, small, medium, large
WHISPER_MODEL=base
